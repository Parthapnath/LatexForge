{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A saved LaTeX translation project with raw text and compiled layout elements.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the project."
        },
        "userId": {
          "type": "string",
          "description": "Firebase Authentication UID of the owner."
        },
        "userEmail": {
          "type": "string",
          "description": "Email address of the owner."
        },
        "title": {
          "type": "string",
          "description": "Human-readable title of the LaTeX document."
        },
        "inputText": {
          "type": "string",
          "description": "Draft or raw text input."
        },
        "latexCode": {
          "type": "string",
          "description": "Translated LaTeX code."
        },
        "mode": {
          "type": "string",
          "enum": [
            "ai",
            "local"
          ],
          "description": "Translation model used (Gemini AI or direct regex translation)."
        },
        "updatedAt": {
          "type": "integer",
          "description": "Unix millisecond timestamp of last edit."
        }
      },
      "required": [
        "id",
        "userId",
        "userEmail",
        "title",
        "inputText",
        "latexCode",
        "mode",
        "updatedAt"
      ]
    }
  },
  "firestore": {
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Documents owned by registered researchers and authors."
    }
  }
}

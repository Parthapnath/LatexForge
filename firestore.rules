rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'userId', 'userEmail', 'title', 'inputText', 'latexCode', 'mode', 'updatedAt'])
        && data.keys().size() == 8
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
        && data.userEmail is string && data.userEmail.size() <= 256
        && data.title is string && data.title.size() <= 500
        && data.inputText is string && data.inputText.size() <= 200000
        && data.latexCode is string && data.latexCode.size() <= 1000000
        && (data.mode == 'ai' || data.mode == 'local')
        && (data.updatedAt is int || data.updatedAt is float);
    }

    match /projects/{projectId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming());
      
      allow update: if isSignedIn() && isValidId(projectId) && isValidProject(incoming())
        && isOwner(existing().userId)
        && incoming().id == existing().id
        && incoming().userId == existing().userId
        && incoming().userEmail == existing().userEmail
        && incoming().updatedAt >= existing().updatedAt;

      allow delete: if isSignedIn() && isValidId(projectId) && isOwner(existing().userId);
    }
  }
}
